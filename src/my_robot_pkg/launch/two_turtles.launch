<launch>

    <!--
    ═══════════════════════════════════════════════════════
    TURTLE 1 — runs in namespace /turtle1_sim
    All topics become:
      /turtle1_sim/turtle1/cmd_vel
      /turtle1_sim/turtle1/pose
    ═══════════════════════════════════════════════════════
    -->
    <group ns="turtle1_sim">

        <!-- Simulator window for turtle 1 -->
        <node pkg="turtlesim"
              type="turtlesim_node"
              name="turtlesim_node"
              output="screen"/>

        <!-- Keyboard controller for turtle 1 -->
        <!-- Opens in its own xterm window -->
        <node pkg="turtlesim"
              type="turtle_teleop_key"
              name="turtle_teleop_key"
              output="screen"
              launch-prefix="xterm -title 'TURTLE 1 CONTROLS — Use Arrow Keys' -e"/>

    </group>

    <!--
    ═══════════════════════════════════════════════════════
    TURTLE 2 — runs in namespace /turtle2_sim
    All topics become:
      /turtle2_sim/turtle1/cmd_vel
      /turtle2_sim/turtle1/pose
    ═══════════════════════════════════════════════════════
    -->
    <group ns="turtle2_sim">

        <!-- Simulator window for turtle 2 -->
        <node pkg="turtlesim"
              type="turtlesim_node"
              name="turtlesim_node"
              output="screen"/>

        <!-- Keyboard controller for turtle 2 -->
        <!-- Opens in its own xterm window -->
        <node pkg="turtlesim"
              type="turtle_teleop_key"
              name="turtle_teleop_key"
              output="screen"
              launch-prefix="xterm -title 'TURTLE 2 CONTROLS — Use Arrow Keys' -e"/>

    </group>

    <!--
    ═══════════════════════════════════════════════════════
    VISUALIZATION — shows both turtles' topic graph
    ═══════════════════════════════════════════════════════
    -->
    <node pkg="rqt_graph"
          type="rqt_graph"
          name="rqt_graph"/>

</launch>
