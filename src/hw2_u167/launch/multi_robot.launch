<launch>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="paused"    value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui"       value="true"/>
    <arg name="headless"  value="false"/>
    <arg name="debug"     value="false"/>
    <arg name="verbose"   value="false"/>
  </include>

  <!-- tb3_0  x=-9.0 -->
  <group ns="tb3_0">
    <param name="robot_description" command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_burger.urdf.xacro"/>
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="rsp"><param name="tf_prefix" value="tb3_0"/></node>
    <node pkg="gazebo_ros" type="spawn_model" name="spawn_tb3_0" args="-urdf -model tb3_0 -x -9.0 -y -5.0 -z 0.0 -param robot_description"/>
  </group>

