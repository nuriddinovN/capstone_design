<launch>
  <arg name="model" default="burger"/>

  <!-- Start Gazebo empty world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <!-- Spawn TurtleBot3 -->
  <param name="robot_description"
    command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro"/>
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_robot"
    args="-urdf -model turtlebot3 -x 0 -y 0 -z 0 -param robot_description"/>

  <!-- Spawn custom object -->
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_custom_object"
    args="-sdf -database custom_object -x 1.0 -y 1.0 -z 0 -R 1.5707 -model custom_object"/>
    

  <!-- Robot state publisher -->
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher">
    <param name="publish_frequency" value="50.0"/>
  </node>
</launch>
